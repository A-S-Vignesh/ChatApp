# Copy this file to `.env` and fill in your local values. The real `.env` is
# gitignored; production values are set in the Vercel/Netlify dashboard.
#
# All VITE_* values are embedded in the client bundle and are PUBLIC.
# Never put real secrets here.

# Backend API base (no trailing slash)
VITE_AUTH_BASE_URL=http://localhost:5000
VITE_BACKEND_URL=http://localhost:5000/api

# This app's public URL (used as the OAuth post-login redirect target)
VITE_BASE_URL=http://localhost:5173

# VAPID *public* key for Web Push. Generate a keypair with:
#   npx web-push generate-vapid-keys
# Put the matching *private* key in backend/.env (NEVER commit that one).
VITE_VAPID_PUBLIC_KEY=
